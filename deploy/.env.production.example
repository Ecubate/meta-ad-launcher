# Copy to server/.env on the box and fill the CHANGE_ME values.
# Domain: ads.ecubate.com

PORT=3010
DATABASE_URL="postgresql://adlauncher:CHANGE_ME_DB_PASSWORD@localhost:5432/adlauncher"

# ── Meta ──────────────────────────────────────────────────────────────
META_API_VERSION=v21.0
META_APP_ID=1582831913226415
META_APP_SECRET=CHANGE_ME_ROTATED_SECRET
META_OAUTH_REDIRECT=https://ads.ecubate.com/api/meta/oauth/callback

# ── Google (Drive + login) ────────────────────────────────────────────
GOOGLE_CLIENT_ID=CHANGE_ME
GOOGLE_CLIENT_SECRET=CHANGE_ME
GOOGLE_REDIRECT_URI=https://ads.ecubate.com/api/drive/oauth/callback
GOOGLE_AUTH_CALLBACK_URL=https://ads.ecubate.com/api/auth/google/callback

# ── Security / prod flags ─────────────────────────────────────────────
TOKEN_ENCRYPTION_KEY=CHANGE_ME_LONG_RANDOM_32PLUS
SESSION_SECRET=CHANGE_ME_LONG_RANDOM_32PLUS
COOKIE_SECURE=true
ALLOWED_EMAIL_DOMAIN=ecubate.com
DEV_LOGIN=false

# Generate the two random secrets on the box with:  openssl rand -hex 32
