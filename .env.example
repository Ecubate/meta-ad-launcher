# ── Meta Marketing API ───────────────────────────────────────────────
# Graph API version to pin (Meta deprecates versions ~yearly).
META_API_VERSION=v21.0
# App credentials (developers.facebook.com → your Business app).
META_APP_ID=
META_APP_SECRET=
# For your OWN ad accounts: a System User token with ads_management + ads_read.
# Business Settings → System Users → Generate token. Long-lived / non-expiring.
META_SYSTEM_USER_TOKEN=

# ── Google Drive ─────────────────────────────────────────────────────
# OAuth client (Google Cloud Console → APIs & Services → Credentials).
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8787/api/drive/oauth/callback
# Optional: a service-account JSON path for server-to-server Drive access instead of OAuth.
GOOGLE_SERVICE_ACCOUNT_JSON=

# ── Server ───────────────────────────────────────────────────────────
PORT=8787
# SQLite for local dev. Swap to a postgres:// URL for production (and change provider in schema.prisma).
DATABASE_URL="file:./prisma/dev.db"
# Secret used to encrypt stored access tokens at rest (32+ random chars).
TOKEN_ENCRYPTION_KEY=change-me-to-a-long-random-string

# ── Web ──────────────────────────────────────────────────────────────
VITE_API_BASE=http://localhost:8787
